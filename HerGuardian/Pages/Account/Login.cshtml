@page
@model HerGuardian.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-card glass">
    <div class="auth-header">
        <i class="fas fa-shield-heart"></i>
        <h2 class="brand-font">Welcome Back</h2>
        <p class="text-secondary small">Secure your world with HerGuardian</p>
    </div>

    <form method="post">
        <div class="mb-4">
            <label class="small text-secondary fw-bold mb-2">EMAIL ADDRESS</label>
            <input asp-for="Login.Email" class="hg-input" placeholder="Enter your email" required />
        </div>
        <div class="mb-4">
            <label class="small text-secondary fw-bold mb-2">PASSWORD</label>
            <input asp-for="Login.Password" type="password" class="hg-input" placeholder="••••••••" required />
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="rememberMe">
                <label class="form-check-label small text-secondary" for="rememberMe">Remember me</label>
            </div>
            <a href="#" class="small text-primary text-decoration-none fw-bold">Forgot?</a>
        </div>

        <button type="submit" class="hg-btn w-100 py-3 mb-4">Sign In to Safety</button>
        
        <div class="text-center text-secondary small">
            Don't have an account? <a asp-page="/Account/Register" class="text-primary fw-bold text-decoration-none">Create one</a>
        </div>
    </form>
</div>