<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>HerGuardian - Your Safety, Our Priority</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Leaflet for Maps -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/herguardian.css" asp-append-version="true" />
</head>
<body class="bg-dark text-white">
    @{
        var isAccountPage = ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Account") == true;
        var authClass = isAccountPage ? "auth-layout" : "";
    }

    <div class="app-layout @authClass">
        @if (!isAccountPage)
        {
            <!-- DESKTOP SIDEBAR -->
            <nav class="sidebar-nav glass d-none d-md-flex">
                <div class="brand-logo mb-5">
                    <i class="fas fa-shield-heart text-primary me-2"></i>
                    <span class="brand-font">HerGuardian</span>
                </div>
                
                <a asp-page="/Profile/Dashboard" class="side-item @(Context.Request.Path.StartsWithSegments("/Profile/Dashboard") ? "active" : "")">
                    <i class="fas fa-home"></i> <span>Monitor</span>
                </a>
                <a asp-page="/Profile/Contacts" class="side-item @(Context.Request.Path.StartsWithSegments("/Profile/Contacts") ? "active" : "")">
                    <i class="fas fa-user-friends"></i> <span>Contacts</span>
                </a>
                <a asp-page="/Profile/Location" class="side-item @(Context.Request.Path.StartsWithSegments("/Profile/Location") ? "active" : "")">
                    <i class="fas fa-map-marked-alt"></i> <span>Location</span>
                </a>
                <a asp-page="/Profile/Journey" class="side-item @(Context.Request.Path.StartsWithSegments("/Profile/Journey") ? "active" : "")">
                    <i class="fas fa-route"></i> <span>Journey</span>
                </a>
                <a asp-page="/Profile/Settings" class="side-item @(Context.Request.Path.StartsWithSegments("/Profile/Settings") ? "active" : "")">
                    <i class="fas fa-cog"></i> <span>Settings</span>
                </a>

                <div class="mt-auto">
                    <a href="/Logout" class="side-item text-danger">
                        <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
                    </a>
                </div>
            </nav>

            <!-- MOBILE BOTTOM NAV -->
            <nav class="bottom-nav glass d-flex d-md-none">
                <a asp-page="/Profile/Dashboard" class="nav-item @(Context.Request.Path.StartsWithSegments("/Profile/Dashboard") ? "active" : "")">
                    <i class="fas fa-home"></i>
                </a>
                <a asp-page="/Profile/Contacts" class="nav-item @(Context.Request.Path.StartsWithSegments("/Profile/Contacts") ? "active" : "")">
                    <i class="fas fa-user-friends"></i>
                </a>
                <a asp-page="/Profile/Location" class="nav-item @(Context.Request.Path.StartsWithSegments("/Profile/Location") ? "active" : "")">
                    <i class="fas fa-map-marked-alt"></i>
                </a>
                <a asp-page="/Profile/Journey" class="nav-item @(Context.Request.Path.StartsWithSegments("/Profile/Journey") ? "active" : "")">
                    <i class="fas fa-route"></i>
                </a>
                <a asp-page="/Profile/Settings" class="nav-item @(Context.Request.Path.StartsWithSegments("/Profile/Settings") ? "active" : "")">
                    <i class="fas fa-cog"></i>
                </a>
            </nav>
        }

        <div class="content-wrapper @(isAccountPage ? "full-width" : "")">
            <div class="container-fluid @(isAccountPage ? "" : "py-4")">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/herguardian.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>